# LILA Lab Discord Bot Configuration
# Copy this file to .env and fill in your values

# Discord Credentials
DISCORD_TOKEN=your_bot_token_here
GUILD_ID=your_guild_id_here

# Channel IDs
WELCOME_CHANNEL_ID=your_welcome_channel_id
ANNOUNCEMENTS_CHANNEL_ID=your_announcements_channel_id
GENERAL_CHANNEL_ID=your_general_channel_id

# Additional Channels
RESEARCH_CHANNEL_ID=your_research_channel_id
CONTRIBUTIONS_CHANNEL_ID=your_contributions_channel_id
SUPPORT_CHANNEL_ID=your_support_channel_id
JOBS_CHANNEL_ID=your_jobs_channel_id

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
FROM_EMAIL=your_email@gmail.com
