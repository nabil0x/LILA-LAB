# ──────────────────────────────────────────────
# LILA Lab — .gitignore
# Only code, docs, and small config files.
# Data files stay local (see distribution/ for
# external platform manifests & DOIs).
# ──────────────────────────────────────────────

# Python build artifacts
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
*.egg
.venv/
venv/
env/

# Python virtual environment
.benv/
.python-version

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fls
*.fdb_latexmk
*.lof
*.lot
*.log
*.out
*.toc
*.synctex.gz
*.run.xml
*.bcf
texput.log

# ── Large data directories (stay local) ──

# BENI pipeline — raw databases, experiment outputs, model weights
pipelines/beni/Bangla_News_Database/
pipelines/beni/data/
pipelines/beni/database/beni_v0_1.sqlite
pipelines/beni/database/outputs/
pipelines/beni/experiment/outputs/
pipelines/beni/experiment/bnlp-resources/
pipelines/beni/experiment/models/
pipelines/beni/annotation/outputs/

# BENI-specific — large CSV and JSON data (keep small config JSONs tracked)
pipelines/beni/**/*.csv
pipelines/beni/**/*.json

# Dataset — large processed data only
dataset/**/*.csv
dataset/**/*.json

# Data paper — large CSV/JSONL data files
dataset/data/

# Archived OSF upload zip (1.1 GB)
archive/BENI_v1_data_paper_osf_dataset_upload.zip

# ── Model artifacts ──
*.joblib
*.safetensors
*.pth
*.pt
*.h5
*.onnx

# ── Large data files / outputs (NOT config JSON/CSV) ──
# Broad patterns only where data directories are deep;
# small config/benchmark JSONs and CSVs should be tracked.
*.jsonl
*.parquet
*.sqlite
*.sqlite3
*.db
*.tar.gz
*.tgz
*.zip
*.7z
*.rar

# ── Logs ──
*.log
beni-*-*.log

# ── Generated PDFs (source .tex is tracked) ──
*.pdf

# ── OS / editor ──
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.nfs*

# ── Local tool/session state ──
.omo/run-continuation/
.playwright-mcp/

# ── Environment ──
**/.env
**/.env.local
**/.env.*.local
.env
.env.local
.env.*.local

# ── Personal / non-LILA projects ──
personal/
